# Copy to .env and fill in. Values here feed bin/app.ts via dotenv.
# CDK context (-c key=value) takes precedence over these .env values.

# 飞书群自定义机器人 webhook（必填）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 机器人签名校验密钥（开启签名校验时填，否则留空）
FEISHU_WEBHOOK_SECRET=

# 可选：覆盖 AWS 账号 / region（否则用 CDK 默认 env）
# CDK_DEFAULT_ACCOUNT=123456789012
# CDK_DEFAULT_REGION=ap-northeast-1
